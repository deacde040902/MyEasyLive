<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.easylive.base.mapper.VideoSeriesMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.easylive.base.entity.po.VideoSeries">
        <id column="series_id" property="seriesId" />
        <result column="user_id" property="userId" />
        <result column="series_name" property="seriesName" />
        <result column="sort_order" property="sortOrder" />
        <result column="create_time" property="createTime" />
