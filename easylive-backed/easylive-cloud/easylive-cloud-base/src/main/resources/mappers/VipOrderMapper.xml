<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.easylive.base.mapper.VipOrderMapper">

    <select id="selectByUserId" parameterType="string" resultType="com.easylive.base.entity.po.VipOrder">
        SELECT * FROM vip_order WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>

    <select id="selectByStatus" parameterType="integer" resultType="com.easylive.base.entity.po.VipOrder">
        SELECT * FROM vip_order WHERE status = #{status} ORDER BY create_time DESC
    </select>

</mapper>
