<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.easylive.base.mapper.UserConversationMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.easylive.base.entity.po.UserConversation">
        <id column="id" property="id" />
        <result column="user_id" property="userId" />
        <result column="target_id" property="targetId" />
        <result column="last_message" property="lastMessage" />
        <result column="last_message_time" property="lastMessageTime" />
        <result column="unread_count" property="unreadCount" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, user_id, target_id, last_message, last_message_time, unread_count
    </sql>

</mapper>
