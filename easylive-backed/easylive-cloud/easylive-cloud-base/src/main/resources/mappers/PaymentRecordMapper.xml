<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.easylive.base.mapper.PaymentRecordMapper">

    <select id="selectByOrderId" parameterType="string" resultType="com.easylive.base.entity.po.PaymentRecord">
        SELECT * FROM payment_record WHERE order_id = #{orderId} ORDER BY create_time DESC
    </select>

    <select id="selectByUserId" parameterType="string" resultType="com.easylive.base.entity.po.PaymentRecord">
        SELECT * FROM payment_record WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>

</mapper>
